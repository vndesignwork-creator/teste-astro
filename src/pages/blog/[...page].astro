---
import Layout from '../../layouts/Layout.astro';
import { directus, readItems, DIRECTUS_URL } from '../../lib/directus';
import type { GetStaticPathsOptions } from 'astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const articles = await directus.request(
    readItems('artigos', {
      sort: ['-date'],
    })
  );

  return paginate(articles, { pageSize: 6 });
}

const { page } = Astro.props;

// Função para garantir que temos um URL de imagem válido
const getImageUrl = (imageSource: string) => {
	if (!imageSource) return '/blog_dicas.png';
    
    // Se for um link externo completo (http), usamos como está
	if (imageSource.startsWith('http')) {
        return imageSource.includes('.htm') ? '/blog_dicas.png' : imageSource;
    }

    // Se for um ID do Directus, construímos o URL correto
    // Removemos qualquer barra no final do URL base para evitar barras duplas
    const baseUrl = DIRECTUS_URL.endsWith('/') ? DIRECTUS_URL.slice(0, -1) : DIRECTUS_URL;
	return `${baseUrl}/assets/${imageSource}`;
};

---

<Layout title={`Blog de Limpeza | Página ${page.currentPage} | Brilho Impecável`} description="Dicas, guias e novidades sobre o mundo da limpeza profissional e organização do lar.">
	<main>
		<!-- Header Page -->
		<section class="section-padding" style="background: var(--primary-dark); color: white; text-align: center; padding: 6rem 0 8rem;">
			<div class="container">
				<h1 style="font-size: 3.5rem; margin-bottom: 2rem; color: white;">Blog da Limpeza</h1>
				<p style="font-size: 1.25rem; opacity: 0.9; max-width: 700px; margin: 0 auto; line-height: 1.6;">
					Dicas práticas, guias de organização e tudo o que precisa de saber para viver num ambiente verdadeiramente impecável.
				</p>
			</div>
		</section>

		<!-- Blog List Section -->
		<section class="section-padding container">
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
				{page.data.map((post: any) => (
					<div class="card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
						<a href={`/blog/${post.slug}`} style="display: block;">
							<img src={getImageUrl(post.image_url)} alt={post.title} style="width: 100%; height: 250px; object-fit: cover; border-bottom: 1px solid #e2e8f0; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
						</a>
						<div style="padding: 2.5rem; display: flex; flex-direction: column; flex-grow: 1; z-index: 10; background: white;">
							<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; font-size: 0.875rem;">
								<span style="color: var(--primary); font-weight: 700; text-transform: uppercase;">{post.category}</span>
								<span style="color: #64748b;">{post.date}</span>
							</div>
							<a href={`/blog/${post.slug}`} style="text-decoration: none;">
								<h2 style="font-size: 1.6rem; margin-bottom: 1rem; line-height: 1.3; color: var(--dark);">{post.title}</h2>
							</a>
							<p style="color: #334155; margin-bottom: 2rem; flex-grow: 1; line-height: 1.7;">{post.excerpt}</p>
							<a href={`/blog/${post.slug}`} style="color: var(--primary-dark); font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; transition: color 0.3s ease;">
								Ler o artigo completo <span style="font-size: 1.2rem;">→</span>
							</a>
						</div>
					</div>
				))}
			</div>

            <!-- Paginação -->
            <div class="mobile-stack" style="margin-top: 5rem; display: flex; justify-content: center; align-items: center; gap: 1rem;">
                {page.url.prev ? (
                    <a href={page.url.prev} class="btn" style="background: white; border: 1px solid #cbd5e1; color: var(--dark);">← Página Anterior</a>
                ) : (
                    <span class="btn" style="background: #f8fafc; border: 1px solid #e2e8f0; color: #94a3b8; cursor: not-allowed;">← Página Anterior</span>
                )}
                
                <span style="font-weight: 600; color: var(--dark);">Página {page.currentPage} de {page.lastPage}</span>
                
                {page.url.next ? (
                    <a href={page.url.next} class="btn" style="background: white; border: 1px solid #cbd5e1; color: var(--dark);">Próxima Página →</a>
                ) : (
                    <span class="btn" style="background: #f8fafc; border: 1px solid #e2e8f0; color: #94a3b8; cursor: not-allowed;">Próxima Página →</span>
                )}
            </div>
		</section>
		
		<!-- CTA do Blog -->
		<section style="background: #e0f2fe; padding: 4rem 0; text-align: center;">
			<div class="container">
				<h2 style="font-size: 2rem; color: var(--primary-dark); margin-bottom: 1rem;">Prefere deixar o trabalho para os profissionais?</h2>
				<p style="color: #334155; margin-bottom: 2rem; font-size: 1.1rem;">Aproveite o seu fim-de-semana. Nós tratamos da limpeza.</p>
				<a href="/contacto" class="btn btn-primary">Pedir um Orçamento</a>
			</div>
		</section>
	</main>
</Layout>
